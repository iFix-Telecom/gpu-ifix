{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ifixtelecom.com.br/schemas/integration-smoke/sensitive-failover-report/1.0.0",
  "title": "Sensitive Failover Smoke Report",
  "version": "1.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "started_at",
    "finished_at",
    "target",
    "fail_closed",
    "never_external",
    "audit_decision",
    "errors",
    "gates"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "target": {
      "type": "object",
      "required": ["gateway_url", "tenant"],
      "properties": {
        "gateway_url": { "type": "string", "format": "uri" },
        "tenant": { "type": "string" }
      },
      "additionalProperties": false
    },
    "git_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{7,40}$"
    },
    "fail_closed": {
      "type": "object",
      "required": ["status_code", "ok", "retry_after", "envelope_code"],
      "properties": {
        "status_code": { "type": "integer" },
        "ok": { "type": "boolean" },
        "retry_after": { "type": ["string", "integer"] },
        "envelope_code": { "type": "string" },
        "raw_error_body": { "type": "string" }
      },
      "additionalProperties": false
    },
    "never_external": {
      "type": "object",
      "required": ["status_code", "ok", "audit_upstream"],
      "properties": {
        "status_code": { "type": "integer" },
        "ok": { "type": "boolean" },
        "audit_upstream": { "type": "string" },
        "raw_error_body": { "type": "string" }
      },
      "additionalProperties": false
    },
    "audit_decision": {
      "type": "object",
      "required": [
        "status_code",
        "ok",
        "audit_log_row_found",
        "audit_log_content_rows"
      ],
      "properties": {
        "status_code": { "type": "integer" },
        "ok": { "type": "boolean" },
        "audit_log_row_found": { "type": "boolean" },
        "audit_log_content_rows": {
          "type": "integer",
          "minimum": -1,
          "description": "COUNT(*) of ai_gateway.audit_log_content rows for the request_id. 0 = PASS (no sensitive content persisted). -1 = sentinel meaning the audit-DB query did not complete (do not read as a clean result; check `ok` + `raw_error_body`)."
        },
        "raw_error_body": { "type": "string" }
      },
      "additionalProperties": false
    },
    "streaming_fail_fast": {
      "type": "object",
      "description": "Optional gate. TIMING+STATUS ONLY: proves a sensitive streaming request 503s in <500ms (fail-FAST). It does NOT prove the streaming path fails CLOSED / never-external — that proof is the in-process sensitive_block_test.go (D-B4). No request_id is captured for this request and the audit gates do not run against it.",
      "required": ["status_code", "ok", "elapsed_ms"],
      "properties": {
        "status_code": { "type": "integer" },
        "ok": { "type": "boolean" },
        "elapsed_ms": { "type": "integer" },
        "raw_error_body": { "type": "string" }
      },
      "additionalProperties": false
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "gates": {
      "type": "object",
      "required": [
        "fail_closed",
        "never_external",
        "audit_decision",
        "all_passed"
      ],
      "properties": {
        "fail_closed": { "type": "boolean" },
        "never_external": { "type": "boolean" },
        "audit_decision": { "type": "boolean" },
        "streaming_fail_fast": { "type": "boolean" },
        "all_passed": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  }
}
