# pod/.env.example
# Copy to pod/.env (NOT committed) and fill in values before `docker compose up`.
# In production, onstart.sh generates this from Vast.ai env + MinIO bucket config.

# -----------------------------------------------------------------------
# Image tags (leave defaults unless pinning to an older image)
# -----------------------------------------------------------------------
IFIX_AI_POD_IMAGE=ghcr.io/ifixtelecom/ifix-ai-pod:latest
IFIX_AI_POD_HEALTH_BRIDGE_IMAGE=ghcr.io/ifixtelecom/ifix-ai-pod-health-bridge:latest

# -----------------------------------------------------------------------
# Weights directory on the host (onstart.sh downloads to here from MinIO)
# Must contain: qwen/model.gguf, bge-m3/ (HF cache)
# STT was removed in Phase 11.1 — handled off-pod via tier-1 gateway fallback.
# -----------------------------------------------------------------------
WEIGHTS_DIR=/weights

# -----------------------------------------------------------------------
# MinIO / S3 — used by pod/onstart.sh to fetch weights (D-02, D-05, D-06)
# These are consumed by onstart.sh BEFORE docker compose up;
# containers themselves never talk to MinIO.
# -----------------------------------------------------------------------
MINIO_ENDPOINT=https://minio.ifix.example.com
MINIO_REGION=us-east-1
MINIO_BUCKET=ifix-ai-weights
MINIO_ACCESS_KEY=<set-at-pod-creation>
MINIO_SECRET_KEY=<set-at-pod-creation>

# Versioned weight URLs (D-06 — allow rollback)
WEIGHTS_QWEN_KEY=qwen3.5-27b-Q4_K_M/v1.0.0/model.gguf
WEIGHTS_BGE_M3_KEY=bge-m3/v1.0.0/model.tar.gz

# SHA-256 sidecars (D-05 — abort startup on mismatch)
WEIGHTS_QWEN_SHA256=<64-hex-digits-from-upload>
WEIGHTS_BGE_M3_SHA256=<64-hex-digits-from-upload>

# -----------------------------------------------------------------------
# Observability / runtime
# -----------------------------------------------------------------------
ENV=production
LOG_LEVEL=info
# TZ already pinned to America/Sao_Paulo in compose x-common-env anchor

# -----------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------
# - health-bridge PROBE_INTERVAL_SECONDS is set to 10 in docker-compose.yml
#   directly (D-11); override via HEALTH_BRIDGE_PROBE_INTERVAL if needed.
# - dcgm-exporter port 9400 is not configurable via env (hardcoded in compose).
# - Vast.ai injects some env vars on pod creation; compose YAML uses ${VAR:-default}
#   interpolation so unset values fall back safely.
