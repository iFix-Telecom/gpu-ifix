# ============================================================
# /opt/ai-gateway-prod/.env (mode 600, owner pedro:pedro)
# ============================================================
# This file is the DOCUMENTED CONTRACT for the prod env at
# /opt/ai-gateway-prod/.env on n8n-ia-vm (Phase 10 D-10 + D-11).
#
# NEVER commit a populated copy. Every value is a <PLACEHOLDER>
# or a literal default that is safe to commit.
#
# Source of values (operator populates during HUMAN-UAT):
#   - ~/.claude/CLAUDE.md           — CF, OpenRouter, MinIO, Vast.ai, OpenAI keys (D-08 reuse)
#   - sentry.io UI                  — NEW project ifix-ai-gateway-prod DSN (D-14)
#   - openssl rand -hex 24          — Redis password (D-07) + optional BETTER_AUTH_SECRET
#   - gatewayctl admin-key create   — dashboard admin key (D-09)
#   - DO Postgres console           — bd_ai_gateway_prod + bd_ai_dashboard_prod (RESEARCH How To #3)
#
# WARNING — D-08 SHARED-KEY INVARIANT
# -----------------------------------
# Per Phase 10 D-08 (accepted trade-off), prod REUSES dev keys for
# OpenRouter, OpenAI, Vast.ai, and MinIO. Implications:
#   1. Rotating ANY of these keys requires updating BOTH
#      /opt/ai-gateway-dev/.env  (vps-ifix-vm)
#      /opt/ai-gateway-prod/.env (n8n-ia-vm)
#      atomically — leaving one stale means the corresponding upstream
#      breaks in the other environment.
#   2. Spend tracking on OpenRouter / OpenAI dashboards is mixed
#      dev+prod traffic; revisit when per-env billing separation
#      becomes a hard requirement (Phase 11 candidate).
# This file mirrors gateway/.env.portainer.example one-to-one for the
# subset of env vars the prod compose stack references. Add NEW keys
# to BOTH files when extending.

# ============================================================
# --- Runtime ---
# ============================================================
TZ=America/Sao_Paulo
ENV=production
GATEWAY_PORT=8080
LOG_LEVEL=info

# ============================================================
# --- Postgres (DO managed) ---
# ============================================================
# RESEARCH How To #3 + Pitfall 2: schema name `ai_gateway` is HARDCODED
# in 27 migration files + gateway/internal/db/pool.go:35 + every sqlc
# query. The implementable form of D-05 is therefore a NEW DATABASE
# (`bd_ai_gateway_prod`) on the same DO managed instance, NOT a new
# schema. Operator creates the DB via DO console before first deploy.
AI_GATEWAY_PG_DSN=postgres://doadmin:<PASS>@db-grupoifix-do-user-7520351-0.j.db.ondigitalocean.com:25060/bd_ai_gateway_prod?sslmode=require
AI_GATEWAY_PG_MAX_CONNS=10
# First deploy ONLY (D-05). Flip to `false` after the boot log shows
# `goose: applied 27 migrations, current version: 27` and recreate
# the container. Leaving this true causes goose to re-run UpContext
# on every restart (idempotent but wastes ~100ms + opens migration
# race on rolling restart).
AI_GATEWAY_MIGRATE_ON_BOOT=true

# ============================================================
# --- Redis (local container redis-gateway-prod) ---
# ============================================================
# D-07: dedicated container on n8n-ia-vm. Password REQUIRED (unlike
# infra-redis-1 dev which is unauthenticated). No persistence (--save ""
# + --appendonly no) — keyspace is ephemeral (rate-limit counters,
# breaker observations, force-override TTL keys, gw:primary:state
# mirror); restart loses state and reconstructs within ~30 s of
# observation cycles.
AI_GATEWAY_REDIS_ADDR=redis-gateway-prod:6379
AI_GATEWAY_REDIS_PASSWORD=<openssl rand -hex 24>
AI_GATEWAY_REDIS_DB=0

# ============================================================
# --- Upstreams (tier-0 local paths) ---
# ============================================================
# LLM + STT = Vast.ai primary pod when active (PRIMARY_POD_SCHEDULE_DISABLED=true
# by default — operator force-up only). When the primary is asleep, the
# dispatcher falls through to tier-1 (UPSTREAM_LLM_OPENROUTER_*).
UPSTREAM_LLM_URL=http://10.10.10.20:8000
UPSTREAM_STT_URL=http://10.10.10.20:8001
# Tier-0 embed = colocated Infinity (ai-gateway-embed container on
# n8n-ia-vm:7997, 24/7 CPU off-pod per Phase 06.7 D-03). Host-IP path
# (RESEARCH Open Question 3) works regardless of overlay network.
UPSTREAM_EMBED_URL=http://10.10.10.20:7997
UPSTREAM_HEALTH_BRIDGE_URL=http://10.10.10.20:9100

# ============================================================
# --- Tier-1 fallback (REUSE dev keys per D-08) ---
# ============================================================
# OpenRouter chat (currently maps `qwen` alias → deepseek/deepseek-v4-flash:nitro
# via migration 0027 schema row). URL ends at /api NOT /api/v1 — the gateway's
# BuildDirector preserves r.URL.Path=/v1/chat/completions from the inbound
# request; appending /v1 here would produce /v1/v1 (Phase 06.9 boot-time
# fail-fast validation rejects /v1-suffixed values).
UPSTREAM_LLM_OPENROUTER_URL=https://openrouter.ai/api
UPSTREAM_LLM_OPENROUTER_AUTH_BEARER=<from ~/.claude/CLAUDE.md OpenRouter key>
# IMPORTANT — leave empty per Phase 06.9 D-06 (schema row wins).
# Migration 0027 sets the canonical target; empty env var lets the
# schema lookup take precedence. Set a non-empty value here ONLY as
# the per-instance escape hatch when overriding the schema row.
UPSTREAM_LLM_OPENROUTER_MODEL=
UPSTREAM_LLM_OPENROUTER_PROVIDER_ORDER=

# OpenAI Whisper (tier-1 STT fallback) — same key serves embed below.
UPSTREAM_STT_OPENAI_URL=https://api.openai.com
UPSTREAM_STT_OPENAI_AUTH_BEARER=<from ~/.claude/CLAUDE.md OpenAI key>

# OpenAI embeddings (tier-1 fallback; text-embedding-3-small + dimensions=1024
# parity-injected by director for BGE-M3 dimensional compatibility).
UPSTREAM_EMBED_OPENAI_URL=https://api.openai.com
UPSTREAM_EMBED_OPENAI_AUTH_BEARER=<same OpenAI key as above>

# ============================================================
# --- Vast.ai primary + emerg (REUSE dev key + budgets per D-08) ---
# ============================================================
# CLAUDE.md `primary-gpu-shape-06.8-final` — DO NOT CHANGE without
# revisiting Phase 06.8 UAT evidence. 2×RTX 3090 single-pod is the
# only validated shape for the full LLM+STT+TTS stack (4090 24G OOMs
# per UAT 06.6 #16; 5090 32G validated as alternate).
VAST_AI_API_KEY=<from ~/.claude/CLAUDE.md>
VAST_PRICE_CAP_DPH=0.40
PRIMARY_VAST_PRICE_CAP_DPH=0.60
MONTHLY_EMERGENCY_BUDGET_BRL=200
MONTHLY_PRIMARY_BUDGET_BRL=2400
USD_TO_BRL_RATE=5.0
PRIMARY_POD_SCHEDULE_DISABLED=true
PRIMARY_NUM_GPUS=2
PRIMARY_GPU_NAME=RTX 3090
PRIMARY_VAST_MACHINE_ALLOWLIST=43803,55158
PRIMARY_VAST_MACHINE_BLOCKLIST=55942,45778

# ============================================================
# --- MinIO (REUSE dev creds — weights bucket is shared) ---
# ============================================================
MINIO_ENDPOINT=https://s3.ifixtelecom.com.br
MINIO_BUCKET=ai-gateway
MINIO_ACCESS_KEY=<from ~/.claude/CLAUDE.md>
MINIO_SECRET_KEY=<from ~/.claude/CLAUDE.md>

# Weights SHA-256 placeholders — same as dev for now (D-08 shared keys
# imply shared weights bucket). Operator copies values from dev .env.
WEIGHTS_QWEN_SHA256=<sha256 placeholder>
WEIGHTS_WHISPER_SHA256=<sha256 placeholder>
WEIGHTS_BGE_M3_SHA256=<sha256 placeholder>
PRIMARY_QWEN_WEIGHTS_SHA256=<sha256 placeholder>
PRIMARY_WHISPER_WEIGHTS_SHA256=<sha256 placeholder>
PRIMARY_BGEM3_WEIGHTS_SHA256=<sha256 placeholder>

# ============================================================
# --- Sentry (NEW prod project) ---
# ============================================================
# Per D-14: new Sentry project `ifix-ai-gateway-prod` in the existing
# Ifix org. Operator creates the project via sentry.io UI (Settings →
# Projects → Create Project → Platform Go → name ifix-ai-gateway-prod)
# and copies the DSN here. Environment tag = `production` derives from
# ENV above; Release tag = BuildVersion baked into the binary by the
# GHA `-ldflags` step (= `v1.0.0` for the first cut release).
SENTRY_DSN=<from sentry.io UI after creating ifix-ai-gateway-prod project>

# ============================================================
# --- Dashboard (Next.js 15 + Better Auth) ---
# ============================================================
# D-06: dashboard owns its own database (bd_ai_dashboard_prod) with
# Better Auth tables under search_path=dashboard_auth. Symmetric to
# the gateway: new DATABASE, hardcoded SCHEMA name.
BETTER_AUTH_SECRET=<openssl rand -base64 32>
BETTER_AUTH_URL=https://ai-dashboard.converse-ai.app
DASHBOARD_DATABASE_URL=postgres://doadmin:<PASS>@db-grupoifix-do-user-7520351-0.j.db.ondigitalocean.com:25060/bd_ai_dashboard_prod?sslmode=require&options=-c%20search_path%3Ddashboard_auth
# Server-side gateway proxy — dashboard calls /admin/* via the internal
# overlay (intra) using container_name DNS (ifix-ai-gateway:8080).
GATEWAY_BASE_URL=http://ifix-ai-gateway:8080
GATEWAY_ADMIN_KEY=<from `gatewayctl admin-key create --label phase-10-prod`>

# ============================================================
# --- Bootstrap ---
# ============================================================
# First tenant slug seeded by migration 0001. Leave default unless
# you have a specific reason to override.
BOOTSTRAP_TENANT_SLUG=converseai

# ============================================================
# --- Schedule routing (Phase 04) ---
# ============================================================
# Per-route write deadlines (seconds). 0 = no deadline (chat must stream
# indefinitely on SSE). 30 s for embed (small synchronous payloads).
# 120 s for audio (whisper-large-v3 transcription window).
WRITE_TIMEOUT_CHAT_SECONDS=0
WRITE_TIMEOUT_EMBED_SECONDS=30
WRITE_TIMEOUT_AUDIO_SECONDS=120
