# ifix-ai-dashboard — environment template
#
# All five vars are SERVER-SIDE ONLY. None carry a NEXT_PUBLIC_ prefix, so
# none are ever inlined into the client bundle. Set these as Portainer stack
# env vars at deploy time — never commit real values.

# --- Better Auth -----------------------------------------------------------

# Signing secret for Better Auth sessions/cookies.
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# The dashboard's own public URL (Better Auth uses it as the cookie/redirect base).
# e.g. https://gateway-dash.ifixtelecom.com.br
BETTER_AUTH_URL=

# Postgres DSN for the dashboard's OWN auth schema/db — ISOLATED from the
# gateway's `ai_gateway` schema (RESEARCH.md Pitfall 7). The Better Auth
# user/session/account/verification tables live here, nowhere near ai_gateway.
# e.g. postgres://user:pass@host:5432/dashboard?options=-c%20search_path%3Ddashboard_auth
DASHBOARD_DATABASE_URL=

# --- Gateway proxy ---------------------------------------------------------

# Internal URL of the ifix-ai-gateway (the server-side proxy forwards to
# ${GATEWAY_BASE_URL}/admin/*). e.g. http://gateway:8080
GATEWAY_BASE_URL=

# An admin key created via `gatewayctl admin-key create` (Phase 4). Read ONLY
# by src/app/api/gateway/[...path]/route.ts — it never reaches the browser.
GATEWAY_ADMIN_KEY=
