# better-auth declares optional peer deps for every framework adapter it
# supports (@sveltejs/kit, etc.). @sveltejs/kit transitively pulls a vite@8
# peer that conflicts with @vitejs/plugin-react's vite@7 peer — an upstream
# optional-peer collision unrelated to this app's actual dependency tree.
# legacy-peer-deps lets `npm install` (plain, no flags) resolve cleanly,
# matching how converseai-v4's bun install dedupes the same graph.
legacy-peer-deps=true
